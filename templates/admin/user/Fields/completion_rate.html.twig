{% set rate = field.formattedValue|default(0) %}
{% set tone = rate < 50 ? 'danger' : (rate < 80 ? 'warning' : 'success') %}
{% set label = rate < 50 ? 'A reprendre' : (rate < 80 ? 'A completer' : 'Complet') %}

<div style="min-width: 148px;">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <strong>{{ rate }}%</strong>
        <span class="badge badge-{{ tone }}">{{ label }}</span>
    </div>
    <div class="progress" style="height: 6px; background: #e9ecef;">
        <div
            class="progress-bar bg-{{ tone }}"
            role="progressbar"
            style="width: {{ rate }}%;"
            aria-valuenow="{{ rate }}"
            aria-valuemin="0"
            aria-valuemax="100"
        ></div>
    </div>
</div>
