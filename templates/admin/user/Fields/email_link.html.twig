{% set url = ea_url()
    .setController('App\\Controller\\Admin\\UserCrudController')
    .setAction('detail')
    .setEntityId(entity.primaryKeyValue)
%}
<a href="{{ url }}" class="ea-user-email-link" style="display: inline-block; max-width: 180px; white-space: normal; overflow-wrap: anywhere; line-height: 1.25;">
    {{ field.value }}
</a>