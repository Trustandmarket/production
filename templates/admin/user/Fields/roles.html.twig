{% set roles = field.value %}
{% if roles is not iterable %}
    {% set roles = roles ? [roles] : [] %}
{% endif %}

{% set businessRoles = [] %}
{% for role in roles %}
    {% if role != 'ROLE_USER' %}
        {% set businessRoles = businessRoles|merge([role]) %}
    {% endif %}
{% endfor %}

<div class="ea-user-roles" style="display: inline-flex; flex-wrap: wrap; gap: 4px; max-width: 150px; line-height: 1.2;">
    {% if businessRoles is not empty %}
        {% for role in businessRoles %}
            <span class="badge badge-info ea-user-role-badge" style="white-space: normal; overflow-wrap: anywhere;">
                {{ role|replace({'ROLE_': ''}) }}
            </span>
        {% endfor %}
    {% else %}
        <span class="badge badge-light ea-user-role-badge">USER</span>
    {% endif %}
</div>