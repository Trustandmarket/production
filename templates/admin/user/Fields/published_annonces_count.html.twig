<script>
(function () {
    if (window.__eaAnnoncesHeaderTooltipInit) {
        return;
    }
    window.__eaAnnoncesHeaderTooltipInit = true;

    function initAnnoncesHeaderTooltip() {
        var headers = document.querySelectorAll('th');
        headers.forEach(function (th) {
            if (!th || th.dataset.annoncesTooltipBound === '1') {
                return;
            }

            var label = th.textContent ? th.textContent.replace(/\s+/g, ' ').trim() : '';
            if (label !== 'Annonces') {
                return;
            }

            th.dataset.annoncesTooltipBound = '1';
            th.style.whiteSpace = 'nowrap';

            var trigger = document.createElement('button');
            trigger.type = 'button';
            trigger.className = 'btn btn-link p-0 ml-1';
            trigger.setAttribute('aria-label', "Nombre d'annonces publiées");
            trigger.style.verticalAlign = 'middle';
            trigger.style.color = '#6c757d';
            trigger.innerHTML = '<i class="fa fa-info-circle" aria-hidden="true"></i>';
            trigger.title = "Nombre d'annonces publiées";

            th.appendChild(trigger);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnnoncesHeaderTooltip, { once: true });
    } else {
        initAnnoncesHeaderTooltip();
    }
})();
</script>