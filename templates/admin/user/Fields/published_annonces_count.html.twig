<script>
(function () {
    if (window.__eaAnnoncesHeaderTooltipInit) {
        return;
    }
    window.__eaAnnoncesHeaderTooltipInit = true;

    function injectResponsiveStyles() {
        if (document.getElementById('ea-users-responsive-style')) {
            return;
        }

        var style = document.createElement('style');
        style.id = 'ea-users-responsive-style';
        style.textContent = [
            '.global-actions, .page-actions, .content-top-actions { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }',
            '.global-actions .btn, .page-actions .btn, .content-top-actions .btn { white-space: normal; }',
            '.table thead th, .table tbody td { white-space: normal; vertical-align: top; }',
            '.ea-user-display-name { max-width: 150px; }',
            '.ea-user-email-link { max-width: 180px; }',
            '.ea-user-roles { max-width: 150px; }',
            '.ea-user-status-badge { min-width: 88px; text-align: center; }',
            '@media (max-width: 1199.98px) { .table thead th, .table tbody td { padding: 0.6rem 0.5rem; font-size: 0.95rem; } .ea-user-display-name { max-width: 130px !important; } .ea-user-email-link { max-width: 150px !important; } .ea-user-roles { max-width: 120px !important; } .ea-user-status-badge { min-width: 72px !important; font-size: 0.78rem; } }',
            '@media (max-width: 991.98px) { .content-top, .content-header, .page-actions, .global-actions, .content-top-actions { gap: 6px; } .global-actions .btn, .page-actions .btn, .content-top-actions .btn { padding: 0.25rem 0.45rem; font-size: 0.78rem; } .table thead th, .table tbody td { padding: 0.5rem 0.4rem; font-size: 0.88rem; } .ea-user-display-name { max-width: 120px !important; } .ea-user-email-link { max-width: 135px !important; } .ea-user-roles { max-width: 110px !important; } .ea-user-role-badge { font-size: 0.72rem; } .ea-user-status-badge { min-width: 64px !important; font-size: 0.72rem; padding: 0.35em 0.45em; } }',
            '@media (max-width: 767.98px) { .table-responsive, .content-panel-body { overflow-x: auto; } .ea-user-display-name { max-width: 100px !important; } .ea-user-email-link { max-width: 120px !important; } .ea-user-roles { max-width: 96px !important; } }'
        ].join('');

        document.head.appendChild(style);
    }

    function initAnnoncesHeaderTooltip() {
        injectResponsiveStyles();

        var headers = document.querySelectorAll('th');
        headers.forEach(function (th) {
            if (!th || th.dataset.annoncesTooltipBound === '1') {
                return;
            }

            var label = th.textContent ? th.textContent.replace(/\s+/g, ' ').trim() : '';
            if (label !== 'Annonces') {
                return;
            }

            th.dataset.annoncesTooltipBound = '1';

            var sortableLink = th.querySelector('a');
            var host = sortableLink || th;
            host.style.position = 'relative';

            if (host.querySelector('.ea-annonces-info')) {
                return;
            }

            var trigger = document.createElement('span');
            trigger.className = 'ea-annonces-info';
            trigger.setAttribute('aria-label', "Nombre d'annonces publiées");
            trigger.setAttribute('title', "Nombre d'annonces publiées");
            trigger.style.position = 'absolute';
            trigger.style.right = '0';
            trigger.style.top = '50%';
            trigger.style.transform = 'translateY(-50%)';
            trigger.style.color = '#6c757d';
            trigger.style.lineHeight = '1';
            trigger.style.display = 'inline-flex';
            trigger.style.alignItems = 'center';
            trigger.innerHTML = '<i class="fa fa-info-circle" aria-hidden="true"></i>';

            var sortIcon = host.querySelector('.fa, .sort-arrow, svg');
            if (sortIcon) {
                sortIcon.style.opacity = '0';
            }

            host.appendChild(trigger);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnnoncesHeaderTooltip, { once: true });
    } else {
        initAnnoncesHeaderTooltip();
    }
})();
</script>